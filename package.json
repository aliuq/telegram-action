{
  "name": "telegram-action",
  "version": "1.0.4",
  "description": "GitHub Action for sending Telegram messages",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "lint": "biome check . && node scripts/check-scenario-sync.mjs",
    "dev": "bun build ./src/index.ts --outdir dist --target node --watch",
    "local": "bun scripts/run-local.ts",
    "local:watch": "bun --watch scripts/run-local.ts",
    "build": "bun build ./src/index.ts --outdir=dist --target=node --minify --sourcemap=external",
    "test": "bun scripts/test.ts",
    "test:interactive": "bun scripts/test.ts",
    "release": "bun run build && bunx bumpp --push --tag --commit --all && bunx changelogithub"
  },
  "keywords": [
    "github",
    "action",
    "telegram",
    "notification"
  ],
  "author": "AliuQ",
  "homepage": "https://github.com/aliuq/telegram-action",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "grammy": "^1.41.1",
    "telegramify-markdown": "^1.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@clack/prompts": "^1.1.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
