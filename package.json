{
  "name": "telegram-action",
  "version": "2.0.1",
  "description": "GitHub Action for sending Telegram messages",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "tsc --noEmit && biome check .",
    "format": "biome check . --write",
    "test": "bun scripts/test.ts",
    "test:unit": "vitest run",
    "test:validate": "bun scripts/test.ts --mode validate",
    "test:act": "bun scripts/test.ts --mode act",
    "release": "bun run build && bunx bumpp --push --tag --commit --all"
  },
  "keywords": [
    "github",
    "action",
    "telegram",
    "notification"
  ],
  "author": "AliuQ",
  "homepage": "https://github.com/aliuq/telegram-action",
  "license": "MIT",
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@biomejs/biome": "^2.4.10",
    "@clack/prompts": "^1.1.0",
    "@types/node": "^25.5.0",
    "cac": "^7.0.0",
    "grammy": "^1.41.1",
    "telegramify-markdown": "^1.3.2",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
